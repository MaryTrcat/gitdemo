{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build SignLanguageLearningSystem",
      "type": "shell",
      "command": "E:/QT/Tools/CMake_64/bin/cmake.exe",
      "args": [
        "--build",
        "${workspaceFolder}/sign-language-learning-system/build",
        "--target",
        "SignLanguageLearningSystem"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "run SignLanguageLearningSystem",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/run-sign-language-system.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/sign-language-learning-system"
      },
      "dependsOn": "build SignLanguageLearningSystem",
      "problemMatcher": []
    }
  ]
}
